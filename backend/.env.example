# -----------------------------------------------------------------------------
# Backend standalone runtime environment template
# Used when running backend directly (npm run dev / npm start in backend/).
# For Docker Compose runs, root .env is the canonical source.
# -----------------------------------------------------------------------------

NODE_ENV=development
LOG_LEVEL=info
PORT=5000
API_PREFIX=/api
CORS_ORIGIN=*

# Authentication / JWT (use long random values, >=32 chars)
JWT_ACCESS_SECRET=replace-with-strong-random-access-secret
JWT_REFRESH_SECRET=replace-with-strong-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=smart-cargo-backend
JWT_AUDIENCE=smart-cargo-api

# PostgreSQL
# Option A: single URL
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
# Option B: discrete PG* settings
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=smart_cargo
PGPOOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=15000

# DB SSL (for managed PostgreSQL)
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA_PATH=

# Optional startup automation
RUN_MIGRATIONS_ON_BOOT=false
RUN_SEEDS_ON_BOOT=false

# MQTT / EMQX Serverless
MQTT_BROKER_HOST=i8e0f149.ala.asia-southeast1.emqxsl.com
MQTT_BROKER_PORT=8883
MQTT_USERNAME=cabin_node
MQTT_PASSWORD=your_password
MQTT_BROKER_URL=
# Optional CA path for local run (example):
# MQTT_CA_PATH=C:/path/to/emqx-ca.crt
MQTT_CA_PATH=
MQTT_REJECT_UNAUTHORIZED=true
MQTT_TOPIC_FILTER=tenant/+/truck/+/container/+/telemetry
MQTT_CLIENT_ID_PREFIX=smart-cargo-backend
MQTT_CONNECT_TIMEOUT_MS=30000
MQTT_RECONNECT_PERIOD_MS=5000

# Alert engine / jobs
ALERT_HIGH_TEMPERATURE_THRESHOLD_C=35
ALERT_GAS_SPIKE_THRESHOLD_RAW=1500
ALERT_AUTO_RESOLVE_SHOCK=false
OFFLINE_THRESHOLD_MS=30000
OFFLINE_SCAN_INTERVAL_MS=5000

# Ingestion backpressure controls
INGEST_QUEUE_CONCURRENCY=6
INGEST_QUEUE_MAX_BACKLOG=5000

# History API limits
HISTORY_DEFAULT_LIMIT=240
HISTORY_MAX_LIMIT=2000
