# -----------------------------------------------------------------------------
# Smart Cargo Monitoring - Docker Compose environment template
# Copy to .env at repository root.
# This is the canonical env file for docker-compose.yml.
# -----------------------------------------------------------------------------

# Container ports
BACKEND_PORT=5000
FRONTEND_PORT=80

# Frontend API base URL used during Docker image build
VITE_API_URL=https://vish85521-cargo.hf.space/api

# Backend runtime
NODE_ENV=production
LOG_LEVEL=info
API_PREFIX=/api
CORS_ORIGIN=*
OTA_HOST=https://vish85521-cargo.hf.space

# Authentication / JWT (use long random values, >=32 chars)
JWT_ACCESS_SECRET=replace-with-strong-random-access-secret
JWT_REFRESH_SECRET=replace-with-strong-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=smart-cargo-backend
JWT_AUDIENCE=smart-cargo-api

# PostgreSQL (Neon)
# Option A: single URL (recommended)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
# Option B: discrete PG* values (used when DATABASE_URL is empty)
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=smart_cargo
PGPOOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=15000

# DB SSL (for managed PostgreSQL)
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA_PATH=

# Optional startup automation
RUN_MIGRATIONS_ON_BOOT=false
RUN_SEEDS_ON_BOOT=false

# MQTT / EMQX Serverless
MQTT_BROKER_HOST=your-emqx-host.ala.region.emqxsl.com
MQTT_BROKER_PORT=8883
MQTT_USERNAME=your_emqx_username
MQTT_PASSWORD=your_emqx_password
MQTT_BROKER_URL=
MQTT_CA_PATH=
MQTT_REJECT_UNAUTHORIZED=true
MQTT_TOPIC_FILTER=tenant/+/truck/+/container/+/telemetry
MQTT_CLIENT_ID_PREFIX=smart-cargo-backend
MQTT_CONNECT_TIMEOUT_MS=30000
MQTT_RECONNECT_PERIOD_MS=5000

# Alert engine / jobs
ALERT_HIGH_TEMPERATURE_THRESHOLD_C=35
ALERT_GAS_SPIKE_THRESHOLD_RAW=1500
ALERT_AUTO_RESOLVE_SHOCK=false
OFFLINE_THRESHOLD_MS=30000
OFFLINE_SCAN_INTERVAL_MS=5000

# Ingestion backpressure controls
INGEST_QUEUE_CONCURRENCY=6
INGEST_QUEUE_MAX_BACKLOG=5000

# History API limits
HISTORY_DEFAULT_LIMIT=240
HISTORY_MAX_LIMIT=2000

# AI trip summary (Gemini)
AI_TRIP_SUMMARY_ENABLED=true
GEMINI_MODEL=gemini-flash-lite-latest
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_API_KEY_BASE64=QUl6YVN5QnREUUtZN1VCYnp5X21tUDl4U1ktUUxybWdHeE1lMFZv
AI_TRIP_SUMMARY_TIMEOUT_MS=15000

# Optional EMQX CA certificate mount path (host side)
EMQX_CA_CERT_DIR=./certs
