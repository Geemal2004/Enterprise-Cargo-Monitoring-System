# -----------------------------------------------------------------------------
# Smart Cargo Monitoring Integration Environment
# Copy this file to .env at repository root
# -----------------------------------------------------------------------------

# Container ports
BACKEND_PORT=5000
FRONTEND_PORT=80

# Frontend API base URL used during Docker image build
VITE_API_URL=/api

# Backend runtime mode and CORS
NODE_ENV=production
CORS_ORIGIN=*

# EMQX Serverless connection (external broker)
MQTT_BROKER_HOST=i8e0f149.ala.asia-southeast1.emqxsl.com
MQTT_BROKER_PORT=8883
MQTT_USERNAME=cabin_node
MQTT_PASSWORD=6HYUvbJEkeFr9m4
MQTT_REJECT_UNAUTHORIZED=true
MQTT_TOPIC_FILTER=tenant/+/truck/+/container/+/telemetry
MQTT_CLIENT_ID_PREFIX=smart-cargo-backend
MQTT_CONNECT_TIMEOUT_MS=30000
MQTT_RECONNECT_PERIOD_MS=5000

# Offline alert scanner settings
OFFLINE_THRESHOLD_MS=30000
OFFLINE_SCAN_INTERVAL_MS=5000

# Optional EMQX CA certificate mount
# 1) Put emqx-ca.crt in ./certs
# 2) Set MQTT_CA_PATH=/run/certs/emqx-ca.crt
EMQX_CA_CERT_DIR=./certs
MQTT_CA_PATH=
