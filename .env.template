# -----------------------------------------------------------------------------
# Cargo Monitor Environment Variables (.env)
# -----------------------------------------------------------------------------

# Mosquitto MQTT Credentials (Match setup.sh generated passwords)
MQTT_USER=cargo_dashboard
MQTT_PASSWORD=dashboard_password

# MongoDB Connection String (Internal Docker DNS)
MONGO_URI=mongodb://mongodb:27017/cargo_monitor

# Backend JWT Secret for REST API Authentication
JWT_SECRET=ultra_secure_jwt_secret_key_change_me_in_production
